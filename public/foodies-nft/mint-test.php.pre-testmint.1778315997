<?php
declare(strict_types=1);
header('Content-Type: text/html; charset=UTF-8');
function h($v): string { return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8'); }

$uid = trim((string)($_GET['uid'] ?? 'FOODIES-MINT-0001'));
$stars = (int)($_GET['stars'] ?? $_GET['star'] ?? 5);
if (!in_array($stars,[1,3,5],true)) $stars = 5;

$safe = preg_replace('/[^A-Za-z0-9._-]/', '-', $uid);
$recipient = trim((string)($_GET['to'] ?? 'UQCFC6_JIg7YcJDaybYZKNSgETbDb28q-6SArFXItaI5jsCb'));

$cdn = 'https://cdn.jsdelivr.net/gh/oneexpress/foodies@main/public';
$artifactApi = "/foodies-nft/api/nft-artifact-mint.php?fresh=1&uid=".rawurlencode($uid)."&stars=".$stars;
$artifactFinal = "/metadata/foodies/generated/{$safe}-{$stars}star.png";
$metaApi = "/foodies-nft/api/nft-metadata.php?uid=".rawurlencode($uid)."&stars=".$stars;
$metaFinal = "/metadata/foodies/items/{$safe}.json";
$payloadApi = "/foodies-nft/api/build-mint-payload.php?uid=".rawurlencode($uid)."&to=".rawurlencode($recipient)."&star=".$stars;
$verify = "https://expressvisa.one/foodies-nft/verify.php?uid=".rawurlencode($uid);
?>
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Foodies NFT Mint Test</title>
<script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
<style>
body{margin:0;background:#f7f8fa;color:#111;font-family:Arial,Helvetica,sans-serif;padding:18px}
.wrap{max-width:1180px;margin:0 auto}.grid{display:grid;grid-template-columns:420px 1fr;gap:16px}
.card{background:white;border:1px solid #e5e7eb;border-radius:20px;padding:16px;box-shadow:0 10px 28px rgba(0,0,0,.06)}
img{max-width:100%;border-radius:16px;background:#111}.ok{color:#15803d;font-weight:900}.bad{color:#b91c1c;font-weight:900}.wait{color:#b45309;font-weight:900}
button{border:0;border-radius:14px;background:#e60012;color:#fff;padding:13px 16px;font-weight:900;cursor:pointer;margin:4px 4px 4px 0}
input,select{padding:11px;border-radius:12px;border:1px solid #ddd}pre{white-space:pre-wrap;background:#101828;color:#e5e7eb;padding:14px;border-radius:14px;max-height:420px;overflow:auto}
a{color:#e60012;font-weight:800;word-break:break-all}.pill{display:inline-block;border-radius:999px;padding:5px 9px;background:#fff1f2;border:1px solid #fecdd3;font-size:12px;font-weight:900;margin:3px}
@media(max-width:860px){.grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="wrap">
<h1>Foodies NFT Mint Test</h1>
<form>
<input name="uid" value="<?=h($uid)?>">
<select name="stars">
<option value="1" <?=$stars===1?'selected':''?>>1 Star</option>
<option value="3" <?=$stars===3?'selected':''?>>3 Star</option>
<option value="5" <?=$stars===5?'selected':''?>>5 Star</option>
</select>
<input name="to" value="<?=h($recipient)?>" style="width:360px;max-width:100%">
<button>Reload Test</button>
</form>

<p>
<span class="pill">UID: <?=h($uid)?></span>
<span class="pill">Stars: <?=h($stars)?></span>
<span class="pill">Recipient: <?=h($recipient)?></span>
</p>

<div class="grid">
<div class="card">
<h2>QR-Merged NFT PNG</h2>
<img src="<?=h($artifactApi)?>" onerror="markBad('artifactStatus','artifact_failed')">
<p id="artifactStatus" class="wait">checking_artifact...</p>
<p><a target="_blank" href="<?=h($artifactFinal)?>">Open final PNG</a></p>
<p><a target="_blank" href="<?=h($verify)?>">Open verify URL</a></p>
</div>

<div class="card">
<h2>Mint Readiness</h2>
<pre id="status">Booting mint test...</pre>
<div id="ton-connect"></div><br>
<button onclick="runPreflight()">Run Preflight</button>
<button onclick="mintFoodies()">Mint NFT with TON Wallet</button>
<h3>Links</h3>
<p>Metadata API: <a target="_blank" href="<?=h($metaApi)?>"><?=h($metaApi)?></a></p>
<p>Metadata File: <a target="_blank" href="<?=h($metaFinal)?>"><?=h($metaFinal)?></a></p>
<p>Payload API: <a target="_blank" href="<?=h($payloadApi)?>"><?=h($payloadApi)?></a></p>
<pre id="debug">loading...</pre>
</div>
</div>
</div>

<script>
const URLS = {
  artifactApi: <?=json_encode($artifactApi)?>,
  artifactFinal: <?=json_encode($artifactFinal)?>,
  metaApi: <?=json_encode($metaApi)?>,
  metaFinal: <?=json_encode($metaFinal)?>,
  payloadApi: <?=json_encode($payloadApi)?>,
  verify: <?=json_encode($verify)?>,
  cdn: <?=json_encode($cdn)?>
};

const tc = new TON_CONNECT_UI.TonConnectUI({
  manifestUrl: 'https://expressvisa.one/tonconnect-manifest.json',
  buttonRootId: 'ton-connect'
});

function markBad(id,msg){ const el=document.getElementById(id); if(el){el.className='bad';el.textContent=msg;} }
function markOk(id,msg){ const el=document.getElementById(id); if(el){el.className='ok';el.textContent=msg;} }
function setStatus(lines){ document.getElementById('status').textContent = Array.isArray(lines) ? lines.join("\n") : String(lines); }
function debug(obj){ document.getElementById('debug').textContent = JSON.stringify(obj,null,2); }

async function fetchJson(url){
  const r = await fetch(url,{cache:'no-store'});
  const text = await r.text();
  let json;
  try { json = JSON.parse(text); } catch(e){ throw new Error('invalid_json_from_' + url + ': ' + text.slice(0,160)); }
  if(!r.ok) throw new Error('http_' + r.status + '_from_' + url);
  return json;
}

async function headOk(url){
  const r = await fetch(url,{method:'HEAD',cache:'no-store'});
  return {ok:r.ok,status:r.status,type:r.headers.get('content-type'),len:r.headers.get('content-length')};
}

function assertPayload(payload){
  if(!payload || payload.ok !== true) throw new Error(payload && payload.error ? payload.error : 'payload_not_ok');
  if(!payload.tonconnect || !Array.isArray(payload.tonconnect.messages)) throw new Error('missing_tonconnect_messages');
  if(payload.tonconnect.messages.length < 1) throw new Error('empty_tonconnect_messages');

  payload.tonconnect.messages.forEach((m,i)=>{
    if(!m.address) throw new Error('message_'+i+'_missing_address');
    if(!m.amount) throw new Error('message_'+i+'_missing_amount');
    if(!/^\d+$/.test(String(m.amount))) throw new Error('message_'+i+'_amount_not_nanotons_integer');
  });
}

function assertMetadata(meta){
  if(!meta || meta.ok === false) throw new Error(meta && meta.error ? meta.error : 'metadata_not_ok');
  const data = meta.metadata || meta;
  if(!data.name) throw new Error('metadata_missing_name');
  if(!data.image) throw new Error('metadata_missing_image');
  if(!String(data.image).includes('/metadata/foodies/')) throw new Error('metadata_image_not_foodies_path');
  if(!data.attributes && !data.traits) throw new Error('metadata_missing_attributes_or_traits');
}

async function runPreflight(){
  setStatus([
    '1 Artifact API: checking',
    '2 Final PNG: checking',
    '3 Metadata JSON: checking',
    '4 Payload JSON: checking',
    '5 TON wallet: not required for preflight',
    '6 Mint transaction: not submitted'
  ]);

  const artifact = await headOk(URLS.artifactApi);
  if(!artifact.ok) throw new Error('artifact_api_failed_http_' + artifact.status);
  markOk('artifactStatus','artifact_api_ready');

  const meta = await fetchJson(URLS.metaApi);
  assertMetadata(meta);

  const payload = await fetchJson(URLS.payloadApi);
  assertPayload(payload);

  setStatus([
    '1 Artifact API: ready',
    '2 QR Verify URL: ready',
    '3 Metadata traits JSON: ready',
    '5 TON wallet: waiting_user',
    '6 Mint transaction: ready_to_submit'
  ]);

  debug({artifact, metadata:meta, payload});
  return {artifact, meta, payload};
}

async function ensureTonConnected(timeoutMs = 90000){
  await tc.connectionRestored.catch(()=>{});
  if(tc.connected || tc.account || tc.wallet) return true;
  tc.openModal();

  return await new Promise((resolve, reject)=>{
    let done = false;
    const timer = setTimeout(()=>{
      if(done) return;
      done = true;
      reject(new Error('wallet_connect_timeout'));
    }, timeoutMs);

    const unsub = tc.onStatusChange((wallet)=>{
      if(done) return;
      if(wallet || tc.connected || tc.account){
        done = true;
        clearTimeout(timer);
        if(typeof unsub === 'function') unsub();
        resolve(true);
      }
    });
  });
}

async function mintFoodies(){
  try{
    const ready = await runPreflight();

    setStatus([
      '1 Artifact API: ready',
      '2 QR Verify URL: ready',
      '3 Metadata traits JSON: ready',
      '5 TON wallet: connecting',
      '6 Mint transaction: pending'
    ]);

    await ensureTonConnected();

    setStatus([
      '1 Artifact API: ready',
      '2 QR Verify URL: ready',
      '3 Metadata traits JSON: ready',
      '5 TON wallet: connected',
      '6 Mint transaction: requesting_wallet_approval'
    ]);

    const result = await tc.sendTransaction(ready.payload.tonconnect);

    setStatus([
      '1 Artifact API: ready',
      '2 QR Verify URL: ready',
      '3 Metadata traits JSON: ready',
      '5 TON wallet: approved',
      '6 Mint transaction: submitted',
      '',
      'Now check wallet activity / Getgems collection indexing.'
    ]);

  }catch(e){
    setStatus(document.getElementById('status').textContent + "\n\nERROR: " + (e && e.message ? e.message : String(e)));
    debug({error:e && e.message ? e.message : String(e)});
    alert(e && e.message ? e.message : String(e));
  }
}

runPreflight().catch(e=>{
  setStatus('PREFLIGHT ERROR: ' + (e && e.message ? e.message : String(e)));
  debug({error:e && e.message ? e.message : String(e)});
});
</script>
</body>
</html>