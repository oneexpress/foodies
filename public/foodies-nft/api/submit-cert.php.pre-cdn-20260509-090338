function out(array $a, int $code = 200): void {
    http_response_code($code);
    echo json_encode($a, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit;
}

function envv(string $k, string $d = ''): string {
    static $c = null;
    if ($c === null) {
        $c = [];
        foreach (['/var/www/secure/.env', '/var/www/html/visa/.env'] as $f) {
            if (!is_file($f)) continue;
            foreach (file($f, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $l) {
                $l = trim($l);
                if ($l === '' || str_starts_with($l, '#') || !str_contains($l, '=')) continue;
                [$a, $b] = explode('=', $l, 2);
                $c[trim($a)] = trim(trim($b), "\"'");
            }
        }
    }
    return (string)($c[$k] ?? getenv($k) ?: $d);
}

function db(): PDO {
    $h = envv('VISA_DB_HOST', envv('DB_HOST', '127.0.0.1'));
    $n = envv('VISA_DB_NAME', 'visa_db');
    $u = envv('VISA_DB_USER', envv('DB_USER', 'root'));
    $p = envv('VISA_DB_PASS', envv('DB_PASS', ''));
    return new PDO("mysql:host={$h};dbname={$n};charset=utf8mb4", $u, $p, [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
    ]);
}

function foodies_wallet(): string {
    global $wallet;
    foreach ([$wallet ?? '', $_POST['owner_wallet'] ?? '', $_POST['issuer_wallet'] ?? '', $_POST['wallet'] ?? '', $_POST['ton_wallet'] ?? ''] as $v) {
        $v = trim((string)$v);
        if ($v !== '') return $v;
    }
    return '';
}

function clean_uid(string $uid): string {
    return preg_replace('/[^A-Za-z0-9._-]/', '-', $uid);
}

function save_upload(string $key, string $uid, string $dir): string {
    if (empty($_FILES[$key]['tmp_name']) || !is_uploaded_file($_FILES[$key]['tmp_name'])) return '';
    $ext = strtolower(pathinfo($_FILES[$key]['name'] ?? '', PATHINFO_EXTENSION));
    if (!in_array($ext, ['jpg', 'jpeg', 'png', 'webp'], true)) $ext = 'jpg';

    $safeUid = clean_uid($uid);
    $baseDir = "/var/www/html/visa/public/foodies-nft/uploads/{$dir}";
    if (!is_dir($baseDir)) mkdir($baseDir, 0775, true);

    $file = "{$baseDir}/{$safeUid}.{$ext}";
    move_uploaded_file($_FILES[$key]['tmp_name'], $file);
    return "/foodies-nft/uploads/{$dir}/{$safeUid}.{$ext}";
}

function ensure_table(PDO $pdo): void {
    $pdo->exec("
        CREATE TABLE IF NOT EXISTS foodies_rwa_certs (
            id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY,
            cert_uid VARCHAR(80) NOT NULL UNIQUE,
            issue_type VARCHAR(20) DEFAULT 'new',
            parent_cert_uid VARCHAR(80) DEFAULT NULL,
            issuer_wallet VARCHAR(128) DEFAULT NULL,
            owner_wallet VARCHAR(128) DEFAULT NULL,
            chef_name VARCHAR(160) DEFAULT NULL,
            brand_name VARCHAR(180) DEFAULT NULL,
            food_title VARCHAR(180) DEFAULT NULL,
            business_type VARCHAR(80) DEFAULT NULL,
            star_class TINYINT UNSIGNED DEFAULT 1,
            reputation_tier VARCHAR(40) DEFAULT NULL,
            average_score DECIMAL(10,2) DEFAULT 0,
            green_clean_food TINYINT(1) DEFAULT 1,
            location_name VARCHAR(255) DEFAULT NULL,
            address_text VARCHAR(255) DEFAULT NULL,
            google_maps_url TEXT DEFAULT NULL,
            social_link_type VARCHAR(40) DEFAULT NULL,
            social_link_url TEXT DEFAULT NULL,
            signature_food_review TEXT DEFAULT NULL,
            food_image_path VARCHAR(255) DEFAULT NULL,
            chef_image_path VARCHAR(255) DEFAULT NULL,
            branding_image_path VARCHAR(255) DEFAULT NULL,
            verify_url TEXT DEFAULT NULL,
            pdf_url TEXT DEFAULT NULL,
            nft_artifact_url TEXT DEFAULT NULL,
            nft_artifact_cdn TEXT DEFAULT NULL,
            nft_metadata_url TEXT DEFAULT NULL,
            status VARCHAR(30) DEFAULT 'issued',
            responsibility_json LONGTEXT DEFAULT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            KEY idx_cert_uid (cert_uid),
            KEY idx_issuer_wallet (issuer_wallet),
            KEY idx_status (status)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
    ");
}

function foodies_auto_prepare_nft_artifact(string $certUid, int $star): array {
    $safeUid = clean_uid($certUid);
    $publicRoot = '/var/www/html/visa/public';
    $generatedDir = $publicRoot . '/metadata/foodies/generated';
    $itemsDir = $publicRoot . '/metadata/foodies/items';

    if (!is_dir($generatedDir)) mkdir($generatedDir, 0775, true);
    if (!is_dir($itemsDir)) mkdir($itemsDir, 0775, true);

    $verifyUrl = 'https://expressvisa.one/foodies-nft/verify.php?uid=' . rawurlencode($certUid);
    $artifactFile = $generatedDir . '/' . $safeUid . '-' . $star . 'star.png';
    $itemFile = $itemsDir . '/' . $safeUid . '.json';

    $artifactApiLocal = 'https://expressvisa.one/foodies-nft/api/nft-artifact-mint.php?fresh=1&uid=' . rawurlencode($certUid) . '&stars=' . $star;
    $png = @file_get_contents($artifactApiLocal);

    if ($png === false || strlen($png) < 1000) {
        return [
            'ok' => false,
            'error' => 'artifact_generation_failed',
            'artifact_api' => $artifactApiLocal,
            'verify_url' => $verifyUrl,
        ];
    }

    file_put_contents($artifactFile, $png);

    $cdn = 'https://cdn.jsdelivr.net/gh/oneexpress/foodies@main/public';
    $artifactCdn = $cdn . '/metadata/foodies/generated/' . basename($artifactFile);
    $metadataCdn = $cdn . '/metadata/foodies/items/' . basename($itemFile);

    $meta = [
        'name' => '@foodies RWA Reputation Card #' . $certUid,
        'description' => 'Foodies RWA Food Reputation Card with Verify URL QR, Green & Clean Food responsibility, and star-based reputation weight.',
        'image' => $artifactCdn,
        'external_url' => $verifyUrl,
        'attributes' => [
            ['trait_type' => 'Cert UID', 'value' => $certUid],
            ['trait_type' => 'Star Rating', 'value' => $star . ' Star'],
            ['trait_type' => 'Responsibility Unit', 'value' => 'Green & Clean Food'],
            ['trait_type' => 'Verify URL', 'value' => $verifyUrl],
            ['trait_type' => 'Chain', 'value' => 'TON'],
        ],
    ];

    file_put_contents($itemFile, json_encode($meta, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT) . "\n");

    return [
        'ok' => true,
        'verify_url' => $verifyUrl,
        'artifact_file' => '/metadata/foodies/generated/' . basename($artifactFile),
        'artifact_url' => 'https://expressvisa.one/metadata/foodies/generated/' . basename($artifactFile),
        'artifact_cdn' => $artifactCdn,
        'metadata_file' => '/metadata/foodies/items/' . basename($itemFile),
        'metadata_url' => $metadataCdn,
    ];
}

try {
    $walletAddr = foodies_wallet();
    if ($walletAddr === '') out(['ok' => false, 'error' => 'owner_wallet_required'], 400);

    $issueType = trim((string)($_POST['issue_type'] ?? 'new'));
    if (!in_array($issueType, ['new', 'reissue'], true)) $issueType = 'new';

    $parentCertUid = trim((string)($_POST['parent_cert_uid'] ?? ''));

    $chef = trim((string)($_POST['chef_name'] ?? ''));
    $brand = trim((string)($_POST['brand_name'] ?? ''));
    $food = trim((string)($_POST['food_title'] ?? ''));
    $business = trim((string)($_POST['business_type'] ?? 'HomeChise Unit'));
    $loc = trim((string)($_POST['location_text'] ?? $_POST['location_name'] ?? ''));
    $addr = trim((string)($_POST['address_text'] ?? $loc));

    if ($issueType === 'new' && ($chef === '' || $brand === '' || $food === '' || $loc === '')) {
        out(['ok' => false, 'error' => 'missing_required_fields'], 400);
    }

    $star = (int)($_POST['star_class'] ?? 1);
    if (!in_array($star, [1, 3, 5], true)) $star = 1;

    $price = $star === 5 ? 500 : ($star === 3 ? 300 : 100);
    $tier = $star === 5 ? 'MASTER_CHEF' : ($star === 3 ? 'PREMIUM' : 'RECOMMENDED');

    $uidPrefix = $issueType === 'reissue' ? 'FDR' : 'FD';
    $uid = $uidPrefix . $star . '-' . date('Ymd') . '-' . strtoupper(substr(bin2hex(random_bytes(3)), 0, 6));

    $verify = 'https://expressvisa.one/foodies-nft/verify.php?uid=' . rawurlencode($uid);
    $pdf = 'https://expressvisa.one/foodies-nft/pdf-design.php?uid=' . rawurlencode($uid) . '&star=' . $star;

    $foodImg = save_upload('signature_food_upload', $uid, 'food');
    if ($foodImg === '') $foodImg = save_upload('food_image', $uid, 'food');
    $chefImg = save_upload('chef_image', $uid, 'chef');
    $brandImg = save_upload('branding_image', $uid, 'brand');

    $map = trim((string)($_POST['google_maps_url'] ?? ''));
    if ($map === '') {
        $map = 'https://www.google.com/maps/search/?api=1&query=' . rawurlencode(trim($brand . ' ' . $loc . ' ' . $addr));
    }

    $review = trim((string)($_POST['signature_food_review'] ?? ''));
    $socialType = trim((string)($_POST['social_link_type'] ?? ''));
    $socialUrl = trim((string)($_POST['social_link_url'] ?? ''));

    if ($issueType === 'reissue' && $parentCertUid !== '') {
        $chef = $chef !== '' ? $chef : 'Re-Issued Foodies Cert';
        $brand = $brand !== '' ? $brand : $parentCertUid;
        $food = $food !== '' ? $food : 'Foodies RWA Reputation Card';
        $loc = $loc !== '' ? $loc : 'Platform Re-Issue';
        $addr = $addr !== '' ? $addr : $loc;
    }

    $nftArtifact = foodies_auto_prepare_nft_artifact($uid, $star);

    $pdo = db();
    ensure_table($pdo);

    $stmt = $pdo->prepare("
        INSERT INTO foodies_rwa_certs
        (cert_uid, issue_type, parent_cert_uid, issuer_wallet, owner_wallet, chef_name, brand_name, food_title,
         business_type, star_class, reputation_tier, average_score, green_clean_food, location_name, address_text,
         google_maps_url, social_link_type, social_link_url, signature_food_review, food_image_path, chef_image_path,
         branding_image_path, verify_url, pdf_url, nft_artifact_url, nft_artifact_cdn, nft_metadata_url, status, responsibility_json)
        VALUES
        (:uid, :issue_type, :parent, :issuer, :owner, :chef, :brand, :food, :business, :star, :tier, :avg, :gc, :loc, :addr,
         :map, :social_type, :social_url, :review, :foodimg, :chefimg, :brandimg, :verify, :pdf, :artifact_url, :artifact_cdn, :metadata_url, 'issued', :resp)
    ");

    $stmt->execute([
        'uid' => $uid,
        'issue_type' => $issueType,
        'parent' => $parentCertUid ?: null,
        'issuer' => $walletAddr,
        'owner' => FOODIES_COLLECTION_OWNER,
        'chef' => $chef,
        'brand' => $brand,
        'food' => $food,
        'business' => $business,
        'star' => $star,
        'tier' => $tier,
        'avg' => (float)($_POST['average_score'] ?? 0),
        'gc' => 1,
        'loc' => $loc,
        'addr' => $addr,
        'map' => $map,
        'social_type' => $socialType,
        'social_url' => $socialUrl,
        'review' => $review,
        'foodimg' => $foodImg,
        'chefimg' => $chefImg,
        'brandimg' => $brandImg,
        'verify' => $verify,
        'pdf' => $pdf,
        'artifact_url' => $nftArtifact['artifact_url'] ?? '',
        'artifact_cdn' => $nftArtifact['artifact_cdn'] ?? '',
        'metadata_url' => $nftArtifact['metadata_url'] ?? '',
        'resp' => json_encode([
            'Green & Clean Food' => true,
            'Verify QR' => true,
            'Food Safety' => true,
            'Responsible Sourcing' => true,
            'NFT Artifact Ready' => (bool)($nftArtifact['ok'] ?? false),
        ], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES),
    ]);

    out([
        'ok' => true,
        'cert_uid' => $uid,
        'issue_type' => $issueType,
        'parent_cert_uid' => $parentCertUid,
        'verify_url' => $verify,
        'pdf_url' => $pdf,
        'vshare_price' => $price,
        'star_class' => $star,
        'nft_artifact' => $nftArtifact,
        'nft_ready_for_mint' => (bool)($nftArtifact['ok'] ?? false),
    ]);
} catch (Throwable $e) {
    error_log('[foodies submit cert] ' . $e->getMessage());
    out([
        'ok' => false,
        'error' => 'submit_failed',
        'detail' => $e->getMessage(),
    ], 500);
}
