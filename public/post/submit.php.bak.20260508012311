<?php
declare(strict_types=1);

/**
 * ExpressVisa 991 Free Post Submit
 * Version: v2026.05.06-submit-match-post-index-01
 * Changelog:
 * - Match /post/index.php form action="/post/submit.php"
 * - Accept multipart/form-data image upload
 * - Accept all route hidden fields from post index
 * - Insert pending row into visa_db.visa_free_posts
 */

session_start();
ini_set('display_errors', '0');
error_reporting(E_ALL);

function fail(string $msg, int $code = 500, array $extra = []): never {
    http_response_code($code);
    header('Content-Type: text/html; charset=UTF-8');
    $safe = htmlspecialchars($msg, ENT_QUOTES, 'UTF-8');
    echo "<!doctype html><meta charset='utf-8'><title>Submit Failed</title>";
    echo "<body style='font-family:Arial;padding:24px;background:#fff1f2;color:#991b1b'>";
    echo "<h2>❌ Submit Failed</h2><p>{$safe}</p>";
    if ($extra) {
        echo "<pre style='white-space:pre-wrap;background:#fff;padding:12px;border-radius:12px'>";
        echo htmlspecialchars(json_encode($extra, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT), ENT_QUOTES, 'UTF-8');
        echo "</pre>";
    }
    echo "<p><a href='/post/'>← Back to Free Post</a></p>
<script src="/assets/js/991-wallet-sync.js?v=991-unified"></script>
<script src="/assets/991-balance-sync.js?v=991-balance-sync-ux-v1" defer></script>
<link rel="stylesheet" href="/assets/css/991-bottom-nav.css?v=991-latest-full-20260507162825">
<script src="/assets/js/991-bottom-nav.js?v=991-latest-full-20260507162825" defer></script>
</body>";
    exit;
}

function ok(string $postRef): never {
    header('Content-Type: text/html; charset=UTF-8');
    $ref = htmlspecialchars($postRef, ENT_QUOTES, 'UTF-8');
    echo "<!doctype html><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'>";
    echo "<title>Submit Success</title>";
    echo "<body style='font-family:Arial,\"Microsoft YaHei\",sans-serif;background:linear-gradient(135deg,#fff,#fff1f2);padding:24px;color:#111827'>";
    echo "<div style='max-width:680px;margin:40px auto;background:#fff;border:1px solid #ffd1d6;border-radius:28px;padding:28px;box-shadow:0 24px 70px rgba(230,0,35,.12)'>";
    echo "<h1 style='color:#e60023;margin-top:0'>✅ 提交成功 / Submitted</h1>";
    echo "<p style='font-size:18px;font-weight:800'>Post Ref: <code>{$ref}</code></p>";
    echo "<p>您的发布已提交，等待后台审核同步到 Marketplace + Community。</p>";
    echo "<p>Your post is pending approval and will be synced after review.</p>";
    echo "<p><a style='display:inline-block;background:#e60023;color:#fff;text-decoration:none;padding:13px 18px;border-radius:999px;font-weight:900' href='/post/'>继续发布 / Post Again</a></p>";
    echo "</div>";
    echo "";
    echo "
</body>";
    exit;
}

function p(string $key, string $default = ''): string {
    return trim((string)($_POST[$key] ?? $default));
}

set_exception_handler(function (Throwable $e): void {
    error_log('[post/submit.php] '.$e->getMessage().' @ '.$e->getFile().':'.$e->getLine());
    fail('server_error', 500);
});

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    header('Location: /post/');
    exit;
}

$db = @new mysqli('localhost', 'root', '', 'visa_db');
if ($db->connect_errno) {
    fail('db_failed');
}
$db->set_charset('utf8mb4');

$target = p('target');
$listingType = p('listing_type', 'product');

$titleZh = p('title_zh');
$titleEn = p('title_en');
$descZh = p('description_zh');
$descEn = p('description_en');

$title = $titleZh !== '' ? $titleZh : $titleEn;
$description = $descZh !== '' ? $descZh : $descEn;

$priceRaw = p('price', '0');
$price = is_numeric($priceRaw) ? (float)$priceRaw : 0.00;

$whatsapp = p('whatsapp', p('wa'));
$whatsapp = preg_replace('/[^\d+]/', '', $whatsapp) ?: '';

$tonAddress = p('ton_address');

if ($target === '' || $title === '' || $description === '' || $whatsapp === '') {
    fail('missing_required', 422, [
        'required' => ['target', 'title_zh OR title_en', 'description_zh OR description_en', 'whatsapp'],
    ]);
}

$route = [
    'target' => $target,
    'listing_type' => $listingType,
    'ton_address' => $tonAddress,

    'audience_slug' => p('nationality_slug'),
    'category_slug' => p('category_slug'),
    'location_slug' => p('location_slug'),
    'sub_location_slug' => p('sub_location_slug'),

    'audience_zh' => p('nationality_zh'),
    'audience_en' => p('nationality_en'),
    'category_zh' => p('category_zh'),
    'category_en' => p('category_en'),
    'location_zh' => p('location_zh'),
    'location_en' => p('location_en'),
    'sub_location_zh' => p('sub_location_zh'),
    'sub_location_en' => p('sub_location_en'),

    'title_zh' => $titleZh,
    'title_en' => $titleEn,
    'description_zh' => $descZh,
    'description_en' => $descEn,
];

$postRef = 'EP' . date('YmdHis') . strtoupper(substr(bin2hex(random_bytes(6)), 0, 12));

$imagePath = '';
if (!empty($_FILES['image']['name']) && is_uploaded_file($_FILES['image']['tmp_name'])) {
    $allowed = [
        'image/jpeg' => 'jpg',
        'image/png' => 'png',
        'image/webp' => 'webp',
    ];

    $mime = mime_content_type($_FILES['image']['tmp_name']) ?: '';
    if (!isset($allowed[$mime])) {
        fail('invalid_image_type', 422);
    }

    if ((int)$_FILES['image']['size'] > 5 * 1024 * 1024) {
        fail('image_too_large_max_5mb', 422);
    }

    $ext = $allowed[$mime];
    $filename = strtolower($postRef) . '.' . $ext;
    $abs = '/var/www/html/visa/public/uploads/free-posts/' . $filename;

    if (!move_uploaded_file($_FILES['image']['tmp_name'], $abs)) {
        fail('image_upload_failed', 500);
    }

    @chmod($abs, 0644);
    $imagePath = '/uploads/free-posts/' . $filename;
}

$syncMessage = json_encode([
    'route' => $route,
    'source' => 'post_index',
    'image_path' => $imagePath,
    'created_by_ip' => $_SERVER['REMOTE_ADDR'] ?? '',
    'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? '',
], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);

$stmt = $db->prepare("
    INSERT INTO visa_free_posts
    (post_ref,target,listing_type,title,description,price,whatsapp,image_path,sync_status,sync_message,created_at,updated_at)
    VALUES
    (?,?,?,?,?,?,?,?, 'pending', ?, NOW(), NOW())
");

if (!$stmt) {
    fail('prepare_failed', 500, ['detail' => $db->error]);
}

$stmt->bind_param(
    'sssssdsss',
    $postRef,
    $target,
    $listingType,
    $title,
    $description,
    $price,
    $whatsapp,
    $imagePath,
    $syncMessage
);

if (!$stmt->execute()) {
    fail('insert_failed', 500, ['detail' => $stmt->error]);
}

ok($postRef);
