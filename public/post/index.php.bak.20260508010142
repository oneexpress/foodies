  } else {
    $('liveBox').textContent=`🔥 ${$('title_en').value || $('title_zh').value || 'Your posting title'}

🌐 Target Audience: ${$('nationality_en').value || 'Foreign Worker'}
🧾 Type: ${typeVal().toUpperCase()}
📌 Category: ${$('category_en').value || 'Visa & Permit'}
📍 Location: ${$('location_en').value || 'Kuala Lumpur'}${$('sub_location_en').value?' / '+$('sub_location_en').value:' / Select sub-location'}
💰 Price: ${price}

📝 Description:
${$('description_en').value || $('description_zh').value || 'Write product or service details here.'}

💬 WhatsApp:
${wa ? 'https://wa.me/'+wa : 'Add WhatsApp number'}

📘 Facebook:
${$('facebook_link').value || '—'}

🎵 TikTok:
${$('tiktok_link').value || '—'}

📕 XHS:
${$('xhs_link').value || '—'}

——
ExpressVisa One · F&B Marketplace`;
  }
}
function previewImage(e){
  const f=e.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=ev=>$('imgPreview').innerHTML='<img src="'+ev.target.result+'">';
  r.readAsDataURL(f);
}
function validatePost(){
  if(!$('title_zh').value.trim() && !$('title_en').value.trim()){alert(txt('请填写标题','Please enter title'));return false;}
  if(!$('description_zh').value.trim() && !$('description_en').value.trim()){alert(txt('请填写描述','Please enter description'));return false;}
  if(!$('wa').value.trim()){alert('WhatsApp required');return false;}
  return true;
}
async function initAll(){
  reloadLabels();
  await loadNationalities();
  await loadCategories();
  await loadLocations();
  renderPreview();
}
