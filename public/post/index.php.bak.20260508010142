<script>
const $ = id => document.getElementById(id);
function actualTarget(){return $('target').value === 'foreign' ? 'foreign' : 'china';}
function isZh(){return actualTarget()==='china';}
function txt(zh,en){return isZh()?zh:en;}
function typeVal(){return document.querySelector('input[name="listing_type"]:checked')?.value || 'product';}

async function api(type, extra=''){
  const url='/post/api/options.php?type='+encodeURIComponent(type)+extra+'&_='+Date.now();
  const res = await fetch(url,{cache:'no-store',credentials:'same-origin'});
  const text = await res.text();
  let j;
  try{j=JSON.parse(text);}catch(e){throw new Error('Bad selector JSON: '+text.slice(0,120));}
  if(!j.ok) throw new Error(j.error || type);
  return j.rows || [];
}
function addOpt(el,r,placeholder){
  const o=document.createElement('option');
  o.value=r.slug||'';
  o.textContent=placeholder || (isZh()?r.name_zh:r.name_en);
  o.dataset.zh=r.name_zh||'';
  o.dataset.en=r.name_en||'';
  el.appendChild(o);
}
async function loadNationalities(){
  $('nationality').innerHTML='';
  (await api('nationalities','&target='+actualTarget())).forEach(r=>addOpt($('nationality'),r));
}
async function loadCategories(){
  $('category').innerHTML='';
  (await api('categories')).forEach(r=>addOpt($('category'),r));
}
async function loadLocations(){
  $('location').innerHTML='';
  (await api('locations')).forEach(r=>addOpt($('location'),r));
  await loadSubLocations();
}
async function loadSubLocations(){
  $('subloc').innerHTML='';
  addOpt($('subloc'),{slug:'',name_zh:'选择子地区',name_en:'Select sub-location'},txt('选择子地区','Select sub-location'));
  if($('location').value){
    const rows=await api('sublocations','&loc='+encodeURIComponent($('location').value));
    rows.forEach(r=>addOpt($('subloc'),r));
  }
  syncHidden(); renderPreview();
}
function syncHidden(){
  const n=$('nationality').selectedOptions[0], c=$('category').selectedOptions[0], l=$('location').selectedOptions[0], s=$('subloc').selectedOptions[0];
  $('nationality_zh').value=n?.dataset.zh||''; $('nationality_en').value=n?.dataset.en||'';
  $('category_zh').value=c?.dataset.zh||''; $('category_en').value=c?.dataset.en||'';
  $('location_zh').value=l?.dataset.zh||''; $('location_en').value=l?.dataset.en||'';
  $('sub_location_zh').value=s?.dataset.zh||''; $('sub_location_en').value=s?.dataset.en||'';
}
function reloadLabels(){
  $('pageTitle').textContent=txt('免费发广告','Free Post Ads');
  $('pageSub').textContent=txt('左边填写资料 · 右边上方帖子预览 · 右边下方图片预览','Left form · Upper post preview · Lower image preview');
  $('legend').textContent=txt('发布说明：请选择目标社区、国籍、分类、地区与子地区。价格仅填写 RM。','Posting guide: choose target community, nationality, category, location and sub-location. Price is RM only.');
  $('lblNat').textContent=txt('目标人群','Targeting Audience');
  $('lblCat').textContent=txt('分类','Category');
  $('lblLoc').textContent=txt('地区','Location');
  $('lblSub').textContent=txt('子地区','Sub-location');
  $('lblPrice').textContent=txt('价格（仅 RM）','Price (RM only)');
  $('lblWa').textContent=txt('WhatsApp 联系','WhatsApp Contact');
  $('lblImg').textContent=txt('上传图片 / 图片预览','Upload Image / Preview');
  $('typeProduct').textContent=txt('产品','Product');
  $('typeService').textContent=txt('服务','Service');
  $('submitBtn').textContent=txt('提交发布','Submit Posting');
}

async function loadAudienceRoute(){
  const audience = $('nationality').value || '';
  const category = $('category').value || '';
  const target = actualTarget();

  if(!audience || !category){
    if($('routeBox')) $('routeBox').textContent = txt('路由预览：请选择目标人群与分类','Routing preview: choose audience and category');
    return;
  }

  try{
    const r = await fetch('/post/api/audience-route.php?target=' + encodeURIComponent(target) + '&audience=' + encodeURIComponent(audience) + '&category=' + encodeURIComponent(category), {cache:'no-store'});
    const j = await r.json();

    if(!j.ok || !j.route) throw new Error('route failed');

    const x = j.route;
    if(isZh()){
      $('routeBox').textContent =
        '智能路由 / Smart Routing\n' +
        '目标人群：' + x.label_zh + '\n' +
        '社区：' + x.community_url + '\n' +
        '人群标签：' + x.audience_tag + '\n' +
        '分类标签：' + x.category_tag + '\n' +
        'Marketplace 分类：' + x.marketplace_category;
    } else {
      $('routeBox').textContent =
        'Smart Routing\n' +
        'Audience: ' + x.label_en + '\n' +
        'Community: ' + x.community_url + '\n' +
        'Audience Tag: ' + x.audience_tag + '\n' +
        'Category Tag: ' + x.category_tag + '\n' +
        'Marketplace Category: ' + x.marketplace_category;
    }
  }catch(e){
    if($('routeBox')) $('routeBox').textContent = 'Routing preview failed';
  }
}

function renderPreview(){
  syncHidden();
  loadAudienceRoute();
  const wa=($('wa').value||'').replace(/[^0-9]/g,'');
